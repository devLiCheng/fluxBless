datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id          Int          @id @default(autoincrement())
  email       String       @unique
  password    String
  name        String?
  role        String       @default("user") // "user" or "admin"
  orders      Order[]
  cartItems   CartItem[]
  loginLogs   LoginLog[]
  reviews     Review[]
  inquiries   Inquiry[]
  userCoupons UserCoupon[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@map("users")
}

model Category {
  id          Int       @id @default(autoincrement())
  nameZh      String
  nameEn      String
  slug        String    @unique
  description String?
  products    Product[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("categories")
}

model Product {
  id               Int         @id @default(autoincrement())
  nameZh           String
  nameEn           String
  descriptionZh    String      @db.Text
  descriptionEn    String      @db.Text
  price            Decimal     @db.Decimal(10, 2)
  stock            Int         @default(0)
  images           Json        // Storing array of image URLs
  categoryId       Int
  category         Category    @relation(fields: [categoryId], references: [id])
  // Rich detail fields
  materialZh       String?     // 材质（中文）e.g. 天然红玛瑙
  materialEn       String?     // Material (English)
  originZh         String?     // 产地（中文）e.g. 云南腾冲
  originEn         String?     // Origin (English)
  purificationZh   String?     // 清洁保养方式（中文）
  purificationEn   String?     // Care and cleaning method (English)
  benefitsZh       String?     @db.Text  // 材质与设计（中文）
  benefitsEn       String?     @db.Text  // Materials and design (English)
  specWeight       String?     // 重量规格 e.g. 约15g
  specBeadSize     String?     // 珠径 e.g. 8mm
  specBeadCount    String?     // 珠数 e.g. 18颗
  specWristSizeZh  String?     // 适合手围（中文）
  specWristSizeEn  String?     // Wrist Size (English)
  sizingDescZh     String?     @db.Text // 尺寸指南说明（中文）
  sizingDescEn     String?     @db.Text // Sizing Guide Description (English)
  purchaseUrl      String?     @db.Text // 采购/采集来源网址 URL
  tagsZh           String?     // 商品标签（中文，逗号分隔）
  tagsEn           String?     // Product tags (English, comma-separated)
  ratingOverride   Float?
  salesOverride    Int?
  orderItems       OrderItem[]
  cartItems        CartItem[]
  reviews          Review[]
  inquiries        Inquiry[]
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  @@map("products")
}

model Order {
  id              Int         @id @default(autoincrement())
  userId          Int
  user            User        @relation(fields: [userId], references: [id])
  totalAmount     Decimal     @db.Decimal(10, 2)
  status          String      // "pending", "paid", "shipped", "completed", "cancelled"
  paymentMethod   String      // "stripe" or "paypal"
  paymentId       String?     // Stripe Payment Intent ID or PayPal Order ID
  shippingAddress String      @db.Text
  contactPhone    String
  contactEmail    String
  items           OrderItem[]
  couponId        Int?
  coupon          Coupon?     @relation(fields: [couponId], references: [id])
  couponDiscount  Decimal?    @db.Decimal(10, 2)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@map("orders")
}

model OrderItem {
  id        Int     @id @default(autoincrement())
  orderId   Int
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId Int
  product   Product @relation(fields: [productId], references: [id])
  quantity  Int
  price     Decimal @db.Decimal(10, 2)

  @@map("order_items")
}

model CartItem {
  id        Int     @id @default(autoincrement())
  userId    Int
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId Int
  product   Product @relation(fields: [productId], references: [id])
  quantity  Int

  @@map("cart_items")
}

model SystemLog {
  id        Int      @id @default(autoincrement())
  level     String   // "info", "warn", "error"
  message   String   @db.Text
  meta      String?  @db.Text // JSON metadata
  createdAt DateTime @default(now())

  @@map("system_logs")
}

model LoginLog {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  ip        String
  country   String?
  userAgent String?
  loginTime DateTime @default(now())

  @@map("login_logs")
}

model Review {
  id        Int      @id @default(autoincrement())
  productId Int
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  rating    Int      // 1 to 5
  comment   String   @db.Text
  createdAt DateTime @default(now())

  @@map("reviews")
}

model Inquiry {
  id          Int      @id @default(autoincrement())
  name        String?
  contactInfo String
  message     String   @db.Text
  status      String   @default("pending") // "pending", "processed"
  productId   Int?
  product     Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  userId      Int?
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("inquiries")
}

model SystemSetting {
  id        Int      @id @default(autoincrement())
  key       String   @unique
  value     String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("system_settings")
}

model BlogPost {
  id          Int      @id @default(autoincrement())
  titleZh     String
  titleEn     String
  slug        String   @unique
  summaryZh   String   @db.Text
  summaryEn   String   @db.Text
  contentZh   String   @db.Text
  contentEn   String   @db.Text
  coverImage  String?  // Cover image URL
  author      String   @default("FluxBless")
  readTime    Int      @default(5) // in minutes
  published   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("blog_posts")
}

model Coupon {
  id             Int          @id @default(autoincrement())
  code           String       @unique
  discountAmount Decimal      @db.Decimal(10, 2)
  minOrderAmount Decimal      @default(0.00) @db.Decimal(10, 2)
  expiresAt      DateTime
  isActive       Boolean      @default(true)
  userCoupons    UserCoupon[]
  orders         Order[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@map("coupons")
}

model UserCoupon {
  id        Int       @id @default(autoincrement())
  userId    Int
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  couponId  Int
  coupon    Coupon    @relation(fields: [couponId], references: [id], onDelete: Cascade)
  isUsed    Boolean   @default(false)
  usedAt    DateTime?
  claimedAt DateTime  @default(now())

  @@map("user_coupons")
}


